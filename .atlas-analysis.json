  "keyFeatures": [
    "Full AzuraCast OpenAPI coverage (263/263 operations)",
    "Single unified AzuraCast node with operations grouped by API resource/tag",
    "Supports path, query, JSON body, raw body, binary, and multipart form-data",
    "Auto-detects response format (JSON, binary, or text) per endpoint",
    "Public endpoints work without an API key; protected endpoints require one",
    "Backward compatible with legacy operationId and JSON parameter workflows",
    "Dual authentication headers: X-API-Key and Authorization Bearer"
  ],
  "publicApiSurface": [
    "AzuraCast node (n8n INodeType)",
    "AzuraCastApi credential type (renebelloAzuraCastApi)",
    "createDomainOperationConfig(tag)",
    "createUnifiedOperationConfig()",
    "createResourceProperty()",
    "createResourceOperationProperty(tag, resourceValue?)",
    "createResourceFieldProperties(tag, resourceValue?)",
    "createSharedAdvancedProperties()",
    "executeDomainNode(operationMap, fixedOperationId?)",
    "azuraCastCredentialTypeName"
  ]
